# ===========================================
# GOOGLE MAPS LOCATION API - ENVIRONMENT CONFIG
# ===========================================
# Salin file ini menjadi .env dan isi dengan nilai yang sesuai
# JANGAN commit file .env ke version control!

# ===========================================
# GOOGLE CLOUD API KEYS
# ===========================================
# Dapatkan dari Google Cloud Console:
# https://console.cloud.google.com/apis/credentials

# API Key untuk Google Places API (Text Search, Nearby Search)
# ⚠️ PENTING: Ganti dengan API Key Anda dari Google Cloud Console
# Dapatkan dari: https://console.cloud.google.com/apis/credentials
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# API Key untuk Google Maps Embed API
# ⚠️ PENTING: Ganti dengan API Key Anda dari Google Cloud Console
# Dapatkan dari: https://console.cloud.google.com/apis/credentials
GOOGLE_MAPS_EMBED_API_KEY=your_google_maps_embed_api_key_here

# ===========================================
# BACKEND CONFIGURATION
# ===========================================

# Port untuk menjalankan FastAPI server
BACKEND_PORT=8000

# Host untuk menjalankan FastAPI server
BACKEND_HOST=0.0.0.0

# ===========================================
# SECURITY CONFIGURATION
# ===========================================

# API Secret untuk mengamankan endpoint backend
# Gunakan string random yang kuat untuk production
# Jika kosong, autentikasi akan di-skip (development mode)
API_SECRET=your_secret_api_key_here_change_in_production

# Allowed origins untuk CORS (comma-separated)
# Sesuaikan dengan domain Open WebUI Anda
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://127.0.0.1:3000

# ===========================================
# OPEN WEBUI CONFIGURATION
# ===========================================

# URL backend yang akan digunakan oleh Open WebUI Functions
# Untuk Docker, gunakan nama service atau IP container
BACKEND_API_URL=http://localhost:8000

# ===========================================
# LOGGING CONFIGURATION
# ===========================================

# Level logging: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ===========================================
# RATE LIMITING (Optional)
# ===========================================

# Maximum requests per minute per IP (0 = unlimited)
RATE_LIMIT_PER_MINUTE=60

# ===========================================
# GOOGLE MAPS API SETTINGS
# ===========================================

# Default radius untuk nearby search (dalam meter)
DEFAULT_SEARCH_RADIUS=1000

# Maximum results per search
MAX_SEARCH_RESULTS=10
